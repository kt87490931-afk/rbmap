# 서버(Droplet) 배포 시 사용
# .env.production 또는 .env.local 로 복사 후 값 채우기
# 주의: .env.production은 next build 시 로드됨

NEXT_PUBLIC_SUPABASE_URL=https://hmuefzrorckwvexmened.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

NEXTAUTH_SECRET=
NEXTAUTH_URL=https://rbbmap.com
NEXT_PUBLIC_SITE_URL=https://rbbmap.com
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Gemini API (업체소개글·리뷰 AI 생성) — 이브알바와 동일
# 새 키 발급: https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Cron 인증 (리뷰 6시간 자동생성 API 호출 시)
CRON_SECRET=91319391708b4a522eee9d3e90697f9a1252bb768de5f7ab
# Cloudflare 봇 로그 동기화 전용 시크릿 (미설정 시 CRON_SECRET 사용)
CRON_CLOUDFLARE_BOT_SYNC_SECRET=

# Cloudflare Security Events API (봇 로그 수집용)
# API Token 권한: Zone.Security Events:Read
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ZONE_ID=

# IP 차단 (쉼표 구분, 위험 감지된 IP 추가)
# 예: BLOCKED_IPS=34.76.117.34,1.2.3.4
BLOCKED_IPS=

# 텔레그램 알림 (위험 감지 시 즉시 알림) — 랭킹마켓과 동일 ID 사용
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
# 텔레그램 채널 룸빵여지도채널 (옵션) — 비공개: -100xxxxxxxxxx, 공개: @채널명. 봇을 채널 관리자로 추가
TELEGRAM_CHANNEL_ID=
